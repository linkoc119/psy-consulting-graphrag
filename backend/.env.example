# LLM Provider: "ollama", "openai", or "claude"
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct-q6_K

# OpenAI-compatible API settings
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_API_BASE=http://your-openai-compatible-endpoint/v1
OPENAI_MODEL=cx/gpt-5.4

# Claude/Anthropic-compatible API settings
ANTHROPIC_API_KEY=your_anthropic_compatible_api_key_here
ANTHROPIC_API_BASE=http://your-anthropic-compatible-endpoint/v1
ANTHROPIC_MODEL=claude-haiku-4-5

# Common LLM settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Embedding Model
EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
EMBEDDING_DIMENSION=1024

# Reranker Model
RERANKER_MODEL=AITeamVN/Vietnamese_Reranker
RERANKER_TOP_K=5

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=psychology_chunks
QDRANT_VECTOR_SIZE=1024

# Neo4j Graph DB
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# GraphRAG settings
TRIAGE_THRESHOLD_HIGH=4
TRIAGE_THRESHOLD_MEDIUM=3
TRIAGE_THRESHOLD_LOW=1

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# App settings
DEBUG=false
APP_NAME=GraphRAG Psychology Chatbot
APP_VERSION=1.0.0

# Device settings
DEVICE=cpu
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
